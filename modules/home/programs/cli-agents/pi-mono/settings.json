{
  "retry": {
    "enabled": true,
    "maxRetries": 5,
    "baseDelayMs": 5000,
    "maxDelayMs": 60000
  },
  "defaultProvider": "openai-codex",
  "defaultModel": "openai-codex/gpt-5.6-sol:xhigh",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": true,
  "quietStartup": false,
  "collapseChangelog": true,
  "steeringMode": "all",
  "followUpMode": "one-at-a-time",
  "showHardwareCursor": false,
  "doubleEscapeAction": "tree",
  "pi-codex-fast": {
    "enabled": false
  },
  "pi-codex-conversion": {
    "enabled": false
  },
  "enabledModels": [
    "umans-local/umans-glm-5.2",
    "openai-codex/gpt-5.6-sol:high",
    "openai-codex/gpt-5.6-tera:high",
    "openai-codex/gpt-5.6-luna:high"
  ],
  "keybindings": {
    "tui.select.up": ["up", "k"],
    "tui.select.down": ["down", "j"],
    "app.message.followUp": ["tab", "alt+enter"],
    "app.message.dequeue": ["ctrl+alt+u", "alt+up"]
  },
  "enableInstallTelemetry": false
}
