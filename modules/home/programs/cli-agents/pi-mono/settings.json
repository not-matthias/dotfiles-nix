{
  "retry": {
    "enabled": true,
    "maxRetries": 5,
    "baseDelayMs": 5000,
    "maxDelayMs": 60000
  },
  "defaultProvider": "claude-bridge",
  "defaultModel": "claude-bridge/claude-opus-4-7:high",
  "defaultThinkingLevel": "xhigh",
  "hideThinkingBlock": true,
  "quietStartup": false,
  "collapseChangelog": true,
  "steeringMode": "all",
  "followUpMode": "one-at-a-time",
  "showHardwareCursor": false,
  "doubleEscapeAction": "tree",
  "theme": "stylix-latte-red",
  "pi-codex-fast": {
    "enabled": false
  },
  "pi-codex-conversion": {
    "enabled": false
  },
  "enabledModels": [
    "openai-codex/gpt-5.5:xhigh",
    "openai-codex/gpt-5.3-codex:xhigh",
    "openai-codex/gpt-5.3-codex-spark:xhigh",
    "claude-bridge/claude-opus-4-6:high",
    "claude-bridge/claude-opus-4-7:high",
    "claude-bridge/claude-haiku-4-5",
    "claude-bridge/claude-sonnet-4-6"
  ],
  "keybindings": {
    "tui.select.up": ["up", "k"],
    "tui.select.down": ["down", "j"],
    "tui.input.tab": ["left", "right"],
    "app.message.followUp": ["tab", "alt+enter"],
    "app.message.dequeue": ["ctrl+alt+u", "alt+up"]
  },
  "enableInstallTelemetry": false
}
