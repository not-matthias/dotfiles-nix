    "bindings": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {}
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  },
  {
